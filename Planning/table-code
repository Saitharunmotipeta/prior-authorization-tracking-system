Table Facility {
  facility_id int [pk, increment]
  facility_name varchar
  facility_location varchar
  created_at datetime
  is_active boolean
}

Table Department {
  department_id int [pk, increment]
  facility_id int
  department_name varchar
  created_at datetime
  is_active boolean
}

Table Patient {
  patient_id int [pk, increment]
  mrn_number varchar [unique]
  full_name varchar
  dob date
  age tinyint
  gender varchar
  phone_number varchar
  identification_type varchar
  identification_number varchar
  created_at datetime
  is_active boolean
}

Table Payer {
  payer_id int [pk, increment]
  payer_name varchar
  contact_number varchar
  portal_link varchar
  normal_tat_days int
  urgent_tat_days int
  created_at datetime
  is_active boolean
}

Table Policy {
  policy_id int [pk, increment]

  patient_id int
  payer_id int

  policy_number varchar

  policy_start_date date
  policy_expiry_date date

  is_active boolean

  created_at datetime
}

Table CPTCode {
  cpt_code varchar [pk]
  cpt_description varchar
}

Table ICDCode {
  icd_code varchar [pk]
  icd_description varchar
}

Table Encounter {
  encounter_id int [pk, increment]

  patient_id int
  facility_id int
  department_id int

  condition_type varchar
  verification_status varchar
  request_status varchar

  identification_verified boolean
  prescription_verified boolean
  scan_verified boolean
  doctor_notes_verified boolean
  insurance_card_verified boolean

  remarks text

  created_at datetime
  updated_at datetime

  is_active boolean
}

Table AuthorizationRequest {
  auth_id int [pk, increment]

  encounter_id int [unique]
  payer_id int

  priority varchar
  status varchar

  estimated_total_amount decimal
  approved_amount decimal

  submitted_at datetime
  reviewed_at datetime

  expiration_date date

  created_at datetime
  updated_at datetime
}

Table AuthorizationService {
  service_id int [pk, increment]

  auth_id int

  cpt_code varchar
  icd_code varchar

  estimated_cost decimal

  notes text

  created_at datetime
}

Table PeerToPeerReview {
  peer_review_id int [pk, increment]

  encounter_id int
  auth_id int

  request_reason text

  scheduled_at datetime
  completed_at datetime

  review_status varchar

  outcome_notes text

  created_at datetime
  updated_at datetime
}

Table AuditHistory {
  audit_id int [pk, increment]

  encounter_id int
  auth_id int

  entity_id varchar

  action_type varchar

  old_value text
  new_value text

  performed_by_user varchar
  performed_by_role varchar

  remarks text

  created_at datetime
}

Ref: Department.facility_id > Facility.facility_id

Ref: Policy.patient_id > Patient.patient_id
Ref: Policy.payer_id > Payer.payer_id

Ref: Encounter.patient_id > Patient.patient_id
Ref: Encounter.facility_id > Facility.facility_id
Ref: Encounter.department_id > Department.department_id

Ref: AuthorizationRequest.encounter_id > Encounter.encounter_id
Ref: AuthorizationRequest.payer_id > Payer.payer_id

Ref: AuthorizationService.auth_id > AuthorizationRequest.auth_id
Ref: AuthorizationService.cpt_code > CPTCode.cpt_code
Ref: AuthorizationService.icd_code > ICDCode.icd_code

Ref: AuditHistory.encounter_id > Encounter.encounter_id
Ref: AuditHistory.auth_id > AuthorizationRequest.auth_id

Ref: PeerToPeerReview.encounter_id > Encounter.encounter_id
Ref: PeerToPeerReview.auth_id > AuthorizationRequest.auth_id